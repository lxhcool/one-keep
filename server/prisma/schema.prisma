generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  income
  expense
  transfer
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amountCents Int
  note        String?
  occurredAt  DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}
