{
  "name": "one-keep-server",
  "script": "dist/server.js",
  "cwd": "./",
  "instances": 1,
  "exec_mode": "fork",
  "env": {
    "NODE_ENV": "production",
    "PORT": 3002
  },
  "max_memory_restart": "256M",
  "log_date_format": "YYYY-MM-DD HH:mm:ss",
  "error_file": "./logs/error.log",
  "out_file": "./logs/out.log",
  "merge_logs": true
}
