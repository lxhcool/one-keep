# Database — 本地开发用 sqlite，生产用 mysql
# 本地: DB_PROVIDER="sqlite"  DATABASE_URL="file:./dev.db"
# 生产: DB_PROVIDER="mysql"   DATABASE_URL="mysql://user:pass@localhost:3306/one_keep"
DB_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="change-me-to-a-random-secret"

# Server
PORT=3000
HOST="0.0.0.0"
