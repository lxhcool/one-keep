# 服务端环境变量示例
# 复制为 .env 并填写真实值

# 数据库（本地开发直连）
DATABASE_URL="postgresql://onekeeper:yourpassword@localhost:5432/one_keep"

# Docker Compose 中 PostgreSQL 容器用的独立变量（与 DATABASE_URL 保持一致）
DB_NAME=one_keep
DB_USER=onekeeper
DB_PASSWORD=yourpassword

# JWT
JWT_ACCESS_SECRET="change_me_access_secret_at_least_32_chars"
JWT_REFRESH_SECRET="change_me_refresh_secret_at_least_32_chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"

# 服务
PORT=3000
NODE_ENV=development
